@page
@model IssuesModel
@{ ViewData["Title"] = "Выдачи"; }

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">📖 Выдача и возврат</h2>
        @* Проверь: target должен быть #addIssueModal *@
        <button class="btn btn-primary shadow-sm px-4 rounded-pill" data-bs-toggle="modal" data-bs-target="#addIssueModal">
            + Выдать книгу
        </button>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <table class="table mb-0">
                <thead>
                    <tr>
                        <th class="ps-4">Книга</th>
                        <th>Читатель</th>
                        <th>Дата выдачи</th>
                        <th>Статус</th>
                        <th class="text-end pe-4">Действие</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var issue in Model.Issues) {
                        <tr>
                            <td class="ps-4">@issue.Book?.Title</td>
                            <td>@issue.Reader?.FullName</td>
                            <td>@issue.IssueDate.ToShortDateString()</td>
                            <td>
                                @if (issue.ReturnDate.HasValue) {
                                    <span class="badge bg-secondary">Вернули: @issue.ReturnDate.Value.ToShortDateString()</span>
                                } else {
                                    <span class="badge bg-primary text-white">На руках</span>
                                }
                            </td>
                            <td class="text-end pe-4">
                                @if (!issue.ReturnDate.HasValue) {
                                    <form method="post" asp-page-handler="Return" asp-route-id="@issue.Id">
                                        <button type="submit" class="btn btn-sm btn-success rounded-pill px-3">Вернуть</button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@* МОДАЛЬНОЕ ОКНО ВЫДАЧИ *@
<div class="modal fade" id="addIssueModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content shadow-lg border-0">
            <div class="modal-header border-0">
                <h5 class="modal-title fw-bold">📖 Оформить выдачу</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form method="post">
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label class="form-label fw-bold small">ВЫБЕРИТЕ КНИГУ</label>
                        <select name="bookId" class="form-select" required>
                            <option value="">-- Выберите из списка --</option>
                            @foreach (var book in Model.AvailableBooks) {
                                <option value="@book.Id">@book.Title (@book.Author)</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold small">ВЫБЕРИТЕ ЧИТАТЕЛЯ</label>
                        <select name="readerId" class="form-select" required>
                            <option value="">-- Выберите из списка --</option>
                            @foreach (var reader in Model.Readers) {
                                <option value="@reader.Id">@reader.FullName</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-light rounded-pill" data-bs-dismiss="modal">Отмена</button>
                    <button type="submit" class="btn btn-primary rounded-pill px-4 shadow">Выдать книгу</button>
                </div>
            </form>
        </div>
    </div>
</div>