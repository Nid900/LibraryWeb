<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Библиотека</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <style>
        body { background-color: #f8f9fa; color: #212529; transition: 0.3s; }
        .card { background-color: #ffffff !important; color: #212529 !important; }
        .table { --bs-table-bg: #ffffff; color: #212529 !important; }

        .dark-mode { background-color: #121212 !important; color: #ffffff !important; }
        .dark-mode .card { background-color: #1e1e1e !important; border-color: #333 !important; }
        .dark-mode .card-body, .dark-mode .display-4, .dark-mode h5, .dark-mode p { color: #ffffff !important; }

        .dark-mode .table { --bs-table-bg: #1e1e1e !important; color: #ffffff !important; background-color: #1e1e1e !important; }
        .dark-mode .table tr, .dark-mode .table td, .dark-mode .table th { background-color: #1e1e1e !important; color: #ffffff !important; border-color: #333 !important; }
        .dark-mode thead, .dark-mode thead th { background-color: #2d2d2d !important; color: #ffffff !important; }

        .dark-mode .modal-content { background-color: #1e1e1e !important; color: #ffffff !important; border: 1px solid #444; }
        .dark-mode .form-control { background-color: #2b2b2b !important; color: #ffffff !important; border-color: #555 !important; }
        .dark-mode .btn-close { filter: invert(1); }
    </style>
</head>
<body class="@(Context.Request.Cookies["theme"] == "dark" ? "dark-mode" : "")">
    <nav class="navbar navbar-dark bg-dark navbar-expand-lg shadow-sm">
        <div class="container"> 
            <div class="navbar-nav d-flex flex-row">
                <a class="nav-link me-3" asp-page="/Index">Главная</a>
                <a class="nav-link me-3" asp-page="/Books">Книги</a>
                <a class="nav-link me-3" asp-page="/Readers">Читатели</a> 
                <a class="nav-link" asp-page="/Issues">Выдачи</a> 
            </div>
            <button class="btn btn-outline-light ms-auto rounded-pill px-3" onclick="toggleTheme()" id="themeBtn">🌙 Тема</button>
        </div>
    </nav>

    <div class="container mt-4">
        @RenderBody()
    </div>

    <script>
        function updateBtn() {
            const btn = document.getElementById("themeBtn");
            if (!btn) return;
            const isDark = document.body.classList.contains("dark-mode");
            btn.innerHTML = isDark ? "☀️ Светлая" : "🌙 Темная";
        }

        function toggleTheme() {
            const isDark = document.body.classList.toggle("dark-mode");
            localStorage.setItem("theme", isDark ? "dark" : "light");
            document.cookie = "theme=" + (isDark ? "dark" : "light") + ";path=/";
            updateBtn();
        }

        window.addEventListener('DOMContentLoaded', () => {
            if (localStorage.getItem("theme") === "dark") {
                document.body.classList.add("dark-mode");
            }
            updateBtn();
        });
    </script>
</body>
</html>