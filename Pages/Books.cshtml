@page
@model BooksModel
@{ ViewData["Title"] = "Книги"; }

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">📚 Управление книгами</h2>
        @* Проверь: data-bs-target должен быть #addBookModal *@
        <button class="btn btn-success shadow-sm px-4 rounded-pill" data-bs-toggle="modal" data-bs-target="#addBookModal">+ Добавить книгу</button>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <table class="table mb-0">
                <thead>
                    <tr>
                        <th class="ps-4">№</th>
                        <th>Название</th>
                        <th>Автор</th>
                        <th>Статус</th>
                        <th class="text-end pe-4">Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @{ int i = 1; }
                    @foreach (var book in Model.Books) {
                        <tr>
                            <td class="ps-4 fw-bold">@(i++)</td>
                            <td>@book.Title</td>
                            <td>@book.Author</td>
                            <td>
                                <span class="badge @(book.IsIssued ? "bg-warning text-dark" : "bg-success")">
                                    @(book.IsIssued ? "На руках" : "В наличии")
                                </span>
                            </td>
                            <td class="text-end pe-4">
                                <form method="post" asp-page-handler="Delete" asp-route-id="@book.Id" onsubmit="return confirm('Удалить?')">
                                    <button type="submit" class="btn btn-outline-danger btn-sm rounded-pill px-3">🗑 Удалить</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@* Проверь: id модалки должен быть addBookModal *@
<div class="modal fade" id="addBookModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content shadow-lg border-0">
            <div class="modal-header border-0"><h5 class="modal-title fw-bold">📖 Новая книга</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
            <form method="post">
                <div class="modal-body p-4">
                    <div class="mb-3"><label class="form-label fw-bold small">НАЗВАНИЕ</label><input type="text" name="title" class="form-control" required></div>
                    <div class="mb-3"><label class="form-label fw-bold small">АВТОР</label><input type="text" name="author" class="form-control" required></div>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-light rounded-pill" data-bs-dismiss="modal">Отмена</button>
                    <button type="submit" class="btn btn-success rounded-pill px-4 shadow">Сохранить</button>
                </div>
            </form>
        </div>
    </div>
</div>