@page
@model IndexModel
@{
    ViewData["Title"] = "Главная";
}

<h1 class="mb-4">Информационная система библиотеки</h1>

<div class="row mb-5">
    <div class="col-md-4">
        <div class="card text-center shadow-sm">
            <div class="card-body">
                <h5>Всего книг</h5>
                <h2 id="booksCount">@Model.Books.Count</h2>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-center shadow-sm">
            <div class="card-body">
                <h5>В наличии</h5>
                <h2>@Model.Books.Count(b => !b.IsIssued)</h2>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-center shadow-sm">
            <div class="card-body">
                <h5>Выдано</h5>
                <h2>@Model.Books.Count(b => b.IsIssued)</h2>
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-header bg-primary text-white">
        <h4 class="mb-0">Список книг</h4>
    </div>
    <div class="card-body">
        <table class="table table-hover">
            <thead>
                <tr>
                    <th>Название</th>
                    <th>Автор</th>
                    <th>Статус</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var book in Model.Books)
                {
                    <tr>
                        <td>@book.Title</td>
                        <td>@book.Author</td>
                        <td>
                            @if (book.IsIssued) {
                                <span class="badge bg-warning text-dark">На руках</span>
                            } else {
                                <span class="badge bg-success">В наличии</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>